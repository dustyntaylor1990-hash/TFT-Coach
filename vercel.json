{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron-meta",
      "schedule": "0 * * * *"
    }
  ],
  "functions": {
    "api/tftacademy.js": {
      "maxDuration": 30
    },
    "api/cron-meta.js": {
      "maxDuration": 30
    }
  }
}
